#!/bin/bash
set -eou pipefail

# Usage: dev/test [--unit]
#   --unit   Run only unit tests (no Docker required)
#   (none)   Run all tests with local XMTP node (requires Docker)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/_lib.sh"

UNIT_TESTS=false

for arg in "$@"; do
    case $arg in
        --unit)
            UNIT_TESTS=true
            ;;
        --help|-h)
            echo "Usage: dev/test [--unit]"
            echo "  --unit   Run only unit tests (no Docker required)"
            echo "  (none)   Run all tests with local XMTP node (requires Docker)"
            exit 0
            ;;
        *)
            echo "Unknown option: $arg"
            echo "Use --help for usage information"
            exit 1
            ;;
    esac
done

# Filter out noisy XMTP Rust library logs
filter_xmtp_logs() {
    grep -v -E "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" || true
}

if [ "$UNIT_TESTS" = true ]; then
    echo "🧪 Running ConvosCore unit tests (no Docker required)..."
    echo ""
    cd "$DEV_ROOT/ConvosCore"
    swift test --filter "Base64URL|DataHex|Compression|Custom Metadata" 2>&1 | filter_xmtp_logs
    exit 0
fi

echo "🧪 Running ConvosCore integration tests with local XMTP node..."
echo ""

if ! docker info > /dev/null 2>&1; then
    echo "❌ Docker is not running. Please start Docker and try again."
    exit 1
fi

XMTP_SERVICES="xmtp-node xmtp-validation xmtp-anvil xmtp-history xmtp-db xmtp-mlsdb"

echo "🐳 Starting local XMTP node..."
goldilocks_compose pull -q $XMTP_SERVICES
goldilocks_compose up -d $XMTP_SERVICES

echo "⏳ Waiting for XMTP node to be ready..."
max_attempts=30
attempt=0

while [ $attempt -lt $max_attempts ]; do
    if nc -z localhost 5556 2>/dev/null; then
        echo "✅ XMTP node is ready!"
        sleep 3
        break
    fi
    attempt=$((attempt + 1))
    echo "Attempt $attempt/$max_attempts - waiting for XMTP node..."
    sleep 2
done

if [ $attempt -ge $max_attempts ]; then
    echo "❌ XMTP node failed to start within the timeout"
    goldilocks_compose logs $XMTP_SERVICES
    exit 1
fi

echo ""
cd "$DEV_ROOT/ConvosCore"

echo "📦 Building tests..."
if ! swift build --build-tests -q 2>&1 | filter_xmtp_logs; then
    echo "❌ Build failed!"
    goldilocks_compose stop $XMTP_SERVICES
    exit 1
fi

echo "🏃 Running tests..."
swift test --skip-build
test_exit_code=$?

echo ""
echo "🛑 Stopping Docker containers..."
goldilocks_compose stop $XMTP_SERVICES

exit $test_exit_code
