# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Environment / secrets — anything matching .env* except the templates
.env
.env.*
!.env.example
!.env.production.example

# Agent local state — SQLCipher DBs with admins-agent / reports-agent
# private keys. NEVER commit. Wipe via `npm run cli` → Dev environment → Reset.
.agent-data/

# Dev background-process state — pids + logs for the CLI-managed
# server:dev / agents:dev processes.
.dev-run/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage output
coverage/
.nyc_output/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Caches
.cache/
.npm
.pnpm-store/
.yarn/cache
.yarn/install-state.gz
tmp/
temp/
