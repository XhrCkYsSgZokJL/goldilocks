#!/usr/bin/env bash
# Restore drill — end-to-end exercise of backup + restore.
#
# 1. Run a fresh backup against the live dev stack.
# 2. Spin up a parallel compose project (`goldilocks-restore-test`) and
#    restore the most recent snapshot into it.
# 3. Smoke-probe the restored stack (auth challenge round-trip,
#    /healthz, a database row count).
# 4. Tear down the parallel stack.
#
# This is the integration test for F1+F2. Run it whenever the backup or
# restore code changes — if it ever stops passing, that's the moment to
# find out, not on the box-died day.
#
# Usage:
#   ./dev/restore-drill           # full drill
#   ./dev/restore-drill --keep    # leave the restore-test stack running for poking
#
# Exit codes:
#   0    drill passed
#   1    drill failed (see logs above the failure)
#   2    misuse / env issue

set -euo pipefail

KEEP=0
case "${1:-}" in
  --keep) KEEP=1 ;;
  -h|--help)
    sed -n 's/^# \{0,1\}//p' "$0" | sed -n '/^Restore drill/,/^Exit codes/p'
    exit 0
    ;;
  '') ;;
  *) printf 'unknown arg: %s\n' "$1" >&2; exit 2 ;;
esac

# We must run from the repo root (the script is invoked as ./dev/restore-drill).
cd "$(dirname "$0")/.."

REPO_ROOT="$(pwd)"
RESTIC_REPO="${REPO_ROOT}/backups/restic-dev"
RESTIC_PASSPHRASE_FILE="${REPO_ROOT}/dev/restic-passphrase.dev"
TEST_PROJECT="goldilocks-restore-test"

log()   { printf '[drill] %s\n' "$*"; }
err()   { printf '[drill] FAIL: %s\n' "$*" >&2; }
pass()  { printf '[drill] PASS: %s\n' "$*"; }

# ----- preflight ------------------------------------------------------------

[[ -f "${RESTIC_PASSPHRASE_FILE}" ]] \
  || { err "dev passphrase missing: ${RESTIC_PASSPHRASE_FILE}"; exit 2; }

if ! docker compose ls --format json | grep -q '"Name":"goldilocks"'; then
  err "dev stack not running — start it first (./dev/up)"
  exit 2
fi

# ----- step 1: backup -------------------------------------------------------

log "step 1/4: running a fresh dev backup"
docker compose --profile backup run --rm backup

# ----- step 2: restore into parallel project --------------------------------

log "step 2/4: restoring into ${TEST_PROJECT}"

# Clean up any leftover restore-test project from a prior failed drill.
docker compose -p "${TEST_PROJECT}" -f docker-compose.yml down -v 2>/dev/null || true

# Drive the restore against the test project. We override:
#   - COMPOSE_PROJECT_NAME      isolates network + volumes from the live stack
#   - HOST_PG_PORT              avoids 25433 conflict with live postgres
#   - HOST_BACKEND_PORT         avoids 4000 conflict; smoke probe targets 4001
COMPOSE_PROJECT_NAME="${TEST_PROJECT}" \
HOST_PG_PORT=25434 \
HOST_BACKEND_PORT=4001 \
  ./scripts/restore.sh \
    --env dev \
    --yes \
    "${RESTIC_REPO}"

# ----- step 3: smoke probes -------------------------------------------------

log "step 3/4: smoke probes"

# The drill validates restore mechanics, not the backend app. Live dev
# runs backend natively via `npm run server:dev`, so we don't try to
# bring it up in the parallel project (the Dockerfile build isn't
# exercised in normal dev and may not be reproducible).
#
# Instead we verify the restored postgres by querying directly via
# `docker compose exec`:
#   - schema_migrations table exists → db.dump was applied
#   - SELECT count(*) FROM devices succeeds → schema is well-formed

probe_pg_query() {
  local sql="$1"
  local result
  for _ in {1..15}; do
    result="$(docker compose -p "${TEST_PROJECT}" -f docker-compose.yml exec -T goldilocks-db \
      psql -U goldilocks -d goldilocks -tA -c "${sql}" 2>/dev/null || true)"
    if [[ "${result}" =~ ^[0-9]+$ ]]; then
      return 0
    fi
    sleep 1
  done
  return 1
}

if probe_pg_query 'SELECT count(*) FROM schema_migrations;'; then
  pass "schema_migrations queryable (db.dump applied)"
else
  err "schema_migrations probe failed — db.dump likely did not restore"
  exit 1
fi
if probe_pg_query 'SELECT count(*) FROM devices;'; then
  pass "devices table queryable"
else
  err "devices table query failed — schema may be incomplete"
  exit 1
fi

# ----- step 4: tear down (unless --keep) ------------------------------------

if [[ "${KEEP}" -eq 1 ]]; then
  log "step 4/4: --keep set, leaving ${TEST_PROJECT} running"
  log "tear down later with:  docker compose -p ${TEST_PROJECT} -f docker-compose.yml down -v"
else
  log "step 4/4: tearing down ${TEST_PROJECT}"
  docker compose -p "${TEST_PROJECT}" -f docker-compose.yml down -v
fi

log ""
pass "restore drill passed end-to-end"
