{
  "name": "goldilocks-backend",
  "version": "0.1.0",
  "description": "Minimal backend for the Goldilocks Digital iOS app — auth, device registration, push subscriptions, and IPFS-backed attachments.",
  "private": true,
  "type": "module",
  "scripts": {
    "server:dev": "DOTENV_CONFIG_PATH=.env.dev tsx watch src/server.ts",
    "server:start": "node dist/server.js",
    "agents:dev": "DOTENV_CONFIG_PATH=.env.dev tsx watch src/agent/index.ts",
    "agents:start": "node dist/agent/index.js",
    "build": "tsc -p tsconfig.json",
    "migrate": "DOTENV_CONFIG_PATH=.env.dev tsx src/db/migrate.ts",
    "reset": "DOTENV_CONFIG_PATH=.env.dev tsx scripts/reset.ts",
    "migrate-encrypt-columns": "DOTENV_CONFIG_PATH=.env.dev tsx scripts/migrate-encrypt-columns.ts",
    "backfill-admin-upgrade-lookups": "DOTENV_CONFIG_PATH=.env.dev tsx scripts/backfill-admin-upgrade-lookups.ts",
    "spawn-two-sims": "bash scripts/spawn-two-sims.sh",
    "logs:sim": "bash scripts/mirror-sim-logs.sh",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "postinstall": "bash scripts/patch-xmtp-bindings.sh"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@grpc/grpc-js": "^1.12.0",
    "@lighthouse-web3/sdk": "^0.3.7",
    "@xmtp/node-sdk": "6.0.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.1",
    "fastify-type-provider-zod": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.2.2",
    "protobufjs": "^7.4.0",
    "siwe": "^3.0.0",
    "stripe": "^17.7.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.6",
    "drizzle-kit": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
