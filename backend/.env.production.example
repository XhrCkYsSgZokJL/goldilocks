# Goldilocks Backend — PRODUCTION environment template.
#
# This is the template for .env.prod. The CLI (`npm run cli -- --prod`)
# copies it, generates the secrets, and writes .env.prod with chmod 600.
# To do it by hand: copy to .env.prod, fill in every blank (generate
# secrets with `openssl rand -hex 32`), then run `chmod 600 .env.prod`.
# Never commit .env.prod.
#
# See docs/production-setup.md for the full runbook.

# --- Database (Postgres runs in Docker on this box) ---
POSTGRES_USER=goldilocks
POSTGRES_DB=goldilocks
# Strong unique password — generate one, it lives only here.
POSTGRES_PASSWORD=

# --- App ---
# Optional. The 'local' storage provider auto-detects the public URL from
# each incoming request, so attachment URLs follow the tunnel hostname with
# no configuration. Set this only to pin/override that detection.
PUBLIC_BASE_URL=
# Native iOS only — no browser clients, so CORS does not apply. Tighten
# this to a fixed origin once the API is on a stable custom domain.
CORS_ORIGIN=*
LOG_LEVEL=info

# JWT signing secret — REQUIRED, minimum 32 chars.  openssl rand -hex 32
JWT_SECRET=
JWT_TTL_SECONDS=86400

# --- SIWE — baked into the sign-in challenge and MUST match the iOS app's
# Convos/Config/GoldilocksConfig.swift values. Keep these fixed: they are
# an agreement between the two sides, not the live tunnel hostname. Do not
# use the ephemeral quick-tunnel URL here, or sign-in breaks on every
# tunnel restart. A domain you own is a good stable choice. ---
SIWE_DOMAIN=goldilocksdigital.xyz
SIWE_URI=https://goldilocksdigital.xyz/api/v2/me

# --- Attachment storage ---
# 'local'      — store attachment bytes on this box (a Docker volume). No
#                account needed; the iOS app end-to-end encrypts bytes
#                before upload, so only ciphertext is stored. Default.
# 'lighthouse' — store on Lighthouse/IPFS; requires LIGHTHOUSE_API_KEY.
STORAGE_PROVIDER=local
# Only used when STORAGE_PROVIDER=lighthouse.
LIGHTHOUSE_API_KEY=
IPFS_GATEWAY=https://gateway.lighthouse.storage/ipfs
# Where the 'local' provider writes attachment bytes inside the container.
# docker-compose.prod.yml already sets this and mounts a matching volume,
# so you normally don't need to change it.
LOCAL_STORAGE_DIR=/var/lib/goldilocks-attachments

# --- XMTP (production network) ---
XMTP_NETWORK=production
# XMTP production gRPC endpoint, used to verify inbox identities.
# Confirm the current value against XMTP's docs before launch (see runbook).
XMTP_GRPC_URL=
XMTP_GRPC_SECURE=true

# --- Server-side agents ---
# 32-byte hex key encrypting the agents' local DBs.  openssl rand -hex 32
# CRITICAL: back this up. Losing it means losing the agent identities.
AGENT_DB_ENCRYPTION_KEY=

# --- Cloudflare tunnel ---
# The quick tunnel needs no token, no account, and no domain — cloudflared
# in docker-compose.prod.yml runs it automatically. Leave this blank.
# Fill it in only if you switch docker-compose.prod.yml to the named tunnel
# (stable custom domain). See docs/production-setup.md.
CLOUDFLARE_TUNNEL_TOKEN=

# --- Stripe billing (subscriptions + one-time support payments) ---
# Use LIVE-MODE keys in production — sk_live_… from
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Signing secret for the webhook endpoint you register in the Stripe
# dashboard (Developers → Webhooks) pointing at
#   https://<your-domain>/api/v2/stripe/webhook
STRIPE_WEBHOOK_SECRET=
# Optional. Leave blank to use the backend's own /api/v2/billing/return
# + /cancel landing pages.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# --- Push notifications (APNs) — deferred. Not needed for the initial
# production launch. When you enable the notification-server service in
# docker-compose.prod.yml later, uncomment these and fill them in. ---
# APNS_TOPIC=
# APNS_KEY_ID=
# APNS_TEAM_ID=

# NOTE: GOLDILOCKS_ALLOW_SELF_PROMOTE is intentionally absent — it is a
# dev-only backdoor and docker-compose.prod.yml forces it to false.
