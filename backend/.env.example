# Goldilocks Backend — environment variables
# Copy to .env for local dev. Never commit .env.

# HTTP server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres — reuse the dev/up Postgres if convenient, or run your own.
# Default points at the convos-ios docker-compose Postgres.
DATABASE_URL=postgres://postgres:xmtp@localhost:25432/goldilocks

# JWT signing secret. Generate one with: openssl rand -hex 32
# Rotate by changing this value; existing tokens will become invalid.
JWT_SECRET=replace_me_with_openssl_rand_hex_32
JWT_TTL_SECONDS=86400

# Storage provider: lighthouse | mock
STORAGE_PROVIDER=mock

# Lighthouse.storage — used when STORAGE_PROVIDER=lighthouse
# Get a key at https://files.lighthouse.storage/dashboard/api-keys
# Or fund a wallet with ~$100 of ETH/MATIC and use Lighthouse SDK's wallet flow.
LIGHTHOUSE_API_KEY=
# Optional: if you want server-side wallet payment instead of API key
LIGHTHOUSE_WALLET_PRIVATE_KEY=

# IPFS gateway used to construct asset URLs returned to the iOS client
IPFS_GATEWAY=https://gateway.lighthouse.storage/ipfs

# CORS — comma-separated list of allowed origins. * for any.
CORS_ORIGIN=*
