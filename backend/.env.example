# Goldilocks Backend — environment variables (LOCAL DEV)
# This is the template for .env.dev. The CLI (`npm run cli -- --dev`) copies
# it and fills in the secrets for you; or copy it by hand to .env.dev.
# Never commit .env.dev. For production, see .env.production.example.

# HTTP server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Postgres — reuse the dev/up Postgres if convenient, or run your own.
# Default points at the convos-ios docker-compose Postgres.
DATABASE_URL=postgres://postgres:xmtp@localhost:25432/goldilocks

# JWT signing secret. Generate one with: openssl rand -hex 32
# Rotate by changing this value; existing tokens will become invalid.
JWT_SECRET=replace_me_with_openssl_rand_hex_32
JWT_TTL_SECONDS=86400

# Storage provider: local | lighthouse | mock
STORAGE_PROVIDER=mock

# Where the 'local' storage provider writes attachment bytes.
LOCAL_STORAGE_DIR=./.attachments

# Lighthouse.storage — used when STORAGE_PROVIDER=lighthouse
# Get a key at https://files.lighthouse.storage/dashboard/api-keys
# Or fund a wallet with ~$100 of ETH/MATIC and use Lighthouse SDK's wallet flow.
LIGHTHOUSE_API_KEY=
# Optional: if you want server-side wallet payment instead of API key
LIGHTHOUSE_WALLET_PRIVATE_KEY=

# IPFS gateway used to construct asset URLs returned to the iOS client
IPFS_GATEWAY=https://gateway.lighthouse.storage/ipfs

# CORS — comma-separated list of allowed origins. * for any.
CORS_ORIGIN=*

# SIWE (Sign-In with Ethereum) — these get embedded in the challenge
# message the iOS app signs. They MUST match the iOS-side constants in
# Convos/Config/GoldilocksConfig.swift. Changing them invalidates any
# in-flight challenges.
SIWE_DOMAIN=local.goldilocksdigital.xyz
SIWE_URI=http://localhost:4000/api/v2/me

# XMTP gRPC — the local XMTP node where we look up inbox identity ledgers.
# Defaults match `convos-ios/dev/up`. Set XMTP_GRPC_SECURE=true in prod.
XMTP_GRPC_URL=localhost:5556
XMTP_GRPC_SECURE=false

# Server-side agents (admins-agent, reports-agent). Connect to the same
# XMTP node the iOS app talks to. The convos-ios local node serves gRPC
# on port 5556 over h2c (HTTP/2 cleartext). When running the agent
# locally, use localhost:5556. When dockerizing later, use
# host.docker.internal:5556 from inside the container.
XMTP_NETWORK=local
XMTP_API_URL=http://localhost:5556

# Where each agent stores its local SQLCipher DB. Defaults to
# ./.agent-data relative to the working dir so local dev just works.
# Use an absolute path under /var/lib/... in docker.
AGENT_DB_DIR=./.agent-data

# 32-byte hex key used to encrypt the agent's local DB. Generate with:
#   openssl rand -hex 32
# Leave blank to use a noisy dev fallback (logs a warning on every boot).
AGENT_DB_ENCRYPTION_KEY=

# DEV-ONLY. Lets a caller promote themselves to admin via
# POST /v2/admin/promote-self. Useful for testing two-sim flows; NEVER set
# this true in production — any client with a JWT could claim admin.
GOLDILOCKS_ALLOW_SELF_PROMOTE=true

# Admins are managed with the Goldilocks CLI (`npm run cli`) — it creates each admin
# slot with a name and a uniquely-generated upgrade code. The person types
# that code in the iOS debug area's "Upgrade to Admin" row to claim it.
# There is no shared upgrade code to configure here.
