# Goldilocks Backend — environment variables (LOCAL DEV)
# This is the template for .env.dev. The CLI (`npm run cli -- --dev`) copies
# it and fills in the secrets for you; or copy it by hand to .env.dev.
# Never commit .env.dev. For production, see .env.production.example.

# HTTP server
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Public base URL used when the local storage provider builds asset
# URLs for RemoteAttachments. Must be HTTPS — the XMTP iOS SDK rejects
# RemoteAttachment messages whose URL scheme isn't `https://` (libxmtp
# fails the codec decode with `RemoteAttachmentError.invalidScheme`).
#
# In dev we run a Caddy reverse proxy on :4443 with a `tls internal`
# self-signed cert (see dev/Caddyfile). The CLI's Systems → Start
# brings Caddy up automatically and installs the root CA into both
# the macOS System keychain and any booted iOS simulator keychain.
#
# If you leave this blank, the local storage provider falls back to
# building http URLs against PORT/HOST above — that's fine for the
# REST API but breaks attachment delivery on iOS.
PUBLIC_BASE_URL=https://localhost:4443

# --- Internal TLS (F5) ---
#
# The compose stack requires SSL between backend/agent and postgres.
# secrets/tls/ holds the per-env CA + postgres server leaf, generated
# by Settings → Run setup (or directly via ./scripts/init-tls.sh dev).
# The CA cert at secrets/tls/ca.crt is mounted into backend + agent +
# backup containers so they can verify the postgres server cert.
#
# Rotation: Settings → Keys → Renew TLS leaf (annual).

# Postgres — the dev goldilocks-db container publishes 25433 → 5432 with
# user goldilocks / password goldilocks. F5 mTLS is required: the CA at
# secrets/tls/ca.crt pins the server cert, and the client leaf at
# secrets/tls/client-backend.{crt,key} identifies the connecting client
# to Postgres's `cert` auth method. Generated by `scripts/init-tls.sh`.
DATABASE_URL=postgres://goldilocks:goldilocks@localhost:25433/goldilocks?sslmode=verify-full&sslrootcert=secrets/tls/ca.crt&sslcert=secrets/tls/client-backend.crt&sslkey=secrets/tls/client-backend.key

# JWT signing secret. Generate one with: openssl rand -hex 32
# Rotate by changing this value; existing tokens will become invalid.
JWT_SECRET=replace_me_with_openssl_rand_hex_32
# Access-token TTL. Short by design; refresh tokens carry continuity.
JWT_TTL_SECONDS=3600
# Refresh-token TTL — controls how long the refresh chain stays valid.
REFRESH_TTL_DAYS=30

# Storage provider: local | lighthouse | mock
#   local       — backend writes attachment bytes to LOCAL_STORAGE_DIR
#                 and serves them at /v2/_local-asset/... — the path the
#                 iOS client expects for RemoteAttachments to actually
#                 work end-to-end. Recommended default.
#   lighthouse  — IPFS via Lighthouse SDK (requires API key below).
#   mock        — discards bytes, returns dead URLs. Silently breaks
#                 PDF / image / attachment delivery on the client. Kept
#                 for tests; not for real use.
STORAGE_PROVIDER=local

# Where the 'local' storage provider writes attachment bytes.
LOCAL_STORAGE_DIR=./.attachments

# Lighthouse.storage — used when STORAGE_PROVIDER=lighthouse
# Get a key at https://files.lighthouse.storage/dashboard/api-keys
# Or fund a wallet with ~$100 of ETH/MATIC and use Lighthouse SDK's wallet flow.
LIGHTHOUSE_API_KEY=
# Optional: if you want server-side wallet payment instead of API key
LIGHTHOUSE_WALLET_PRIVATE_KEY=

# IPFS gateway used to construct asset URLs returned to the iOS client
IPFS_GATEWAY=https://gateway.lighthouse.storage/ipfs

# CORS — comma-separated list of allowed origins. * for any.
CORS_ORIGIN=*

# SIWE (Sign-In with Ethereum) — these get embedded in the challenge
# message the iOS app signs. They MUST match the iOS-side constants in
# Convos/Config/GoldilocksConfig.swift. Changing them invalidates any
# in-flight challenges.
SIWE_DOMAIN=local.goldilocksdigital.xyz
SIWE_URI=http://localhost:4000/api/v2/me

# XMTP gRPC — the local XMTP node where we look up inbox identity ledgers.
# Defaults match `./dev/start`. Set XMTP_GRPC_SECURE=true in prod.
XMTP_GRPC_URL=localhost:5556
XMTP_GRPC_SECURE=false

# Server-side agents (admins-agent, reports-agent). Connect to the same
# XMTP node the iOS app talks to. The local node serves gRPC
# on port 5556 over h2c (HTTP/2 cleartext). When running the agent
# locally, use localhost:5556. When dockerizing later, use
# host.docker.internal:5556 from inside the container.
XMTP_NETWORK=local
XMTP_API_URL=http://localhost:5556

# Where each agent stores its local SQLCipher DB. Defaults to
# ./.agent-data relative to the working dir so local dev just works.
# Use an absolute path under /var/lib/... in docker.
AGENT_DB_DIR=./.agent-data

# 32-byte hex key used to encrypt the agent's local DB. Generate with:
#   openssl rand -hex 32
# Leave blank to use a noisy dev fallback (logs a warning on every boot).
AGENT_DB_ENCRYPTION_KEY=

# Report-answering agent (Venice LLM). Plumbing only — disabled by default.
# When REPORTS_LLM_ENABLED is false (default) the reports-agent posts its
# canned auto-reply and never calls an LLM. Venice (https://venice.ai) is a
# privacy-first, zero-retention, OpenAI-compatible API. To enable later:
# set a key, pick a model from GET /api/v1/models, then flip the flag.
# See docs/plans/report-agent-llm-venice.md.
REPORTS_LLM_ENABLED=false
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=
VENICE_TIMEOUT_MS=30000

# F4 — App-layer column encryption.
#
# 64 hex chars. Wraps sensitive DB columns (server_agents.private_key_hex,
# admin_inboxes.upgrade_code, clients.stripe_customer_id, billing_checkouts
# Stripe IDs, devices.push_token) in AES-256-GCM with HKDF-per-column key
# derivation. Generated by Settings → Run setup.
#
# Losing this key = losing every encrypted column. The backup snapshots
# .env.<env> so a restore brings it back.
APP_ENCRYPTION_KEY=

# Master flag for at-rest column encryption writes. Reads are always
# tolerant of both formats during the rollout. Setup defaults this to
# true for new installs; existing installs can flip it after running
# Settings → Keys → Encrypt remaining plaintext columns.
ENCRYPT_AT_REST_V1=true

# DEV-ONLY. Lets a caller promote themselves to admin via
# POST /v2/admin/promote-self. Useful for testing two-sim flows; NEVER set
# this true in production — any client with a JWT could claim admin.
GOLDILOCKS_ALLOW_SELF_PROMOTE=true

# ===========================================================================
# PAYMENTS
# ===========================================================================
# All payment providers are optional. Routes return 503 until configured.
# Each provider has its own section below — fill in whichever you're testing.

# --- Stripe (card payments) ---
# Use TEST-MODE keys here — they start with sk_test_ / whsec_.
# Grab the secret key from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret for POST /v2/stripe/webhook. In local dev, run
#   stripe listen --forward-to localhost:4000/api/v2/stripe/webhook
# and paste the whsec_… it prints here.
STRIPE_WEBHOOK_SECRET=
# Where Stripe redirects the browser after checkout. Leave blank to use
# the backend's own /api/v2/billing/return + /cancel pages.
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# --- Apple In-App Purchase (StoreKit 2) ---
# Get these from App Store Connect → Keys → In-App Purchase.
# 1. Create a key at https://appstoreconnect.apple.com/access/integrations/api/subs
# 2. Download the .p8 file (one-time download!)
# 3. Fill in the values below.
# Leave blank to disable; Apple IAP routes return 503.
APPLE_BUNDLE_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_ISSUER_ID=
# Paste the contents of the .p8 file here. Replace newlines with \n:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' AuthKey_XXXXXX.p8
APPLE_PRIVATE_KEY=
# 'sandbox' for dev + TestFlight, 'production' for App Store release.
APPLE_ENVIRONMENT=sandbox

# --- Hopscotch (crypto deposits) ---
# Reserved for Hopscotch payment gateway integration.
HOPSCOTCH_API_KEY=
HOPSCOTCH_WEBHOOK_SECRET=
HOPSCOTCH_ENVIRONMENT=sandbox

# Admins are managed with the Goldilocks CLI (`npm run cli`) — it creates each admin
# slot with a name and a uniquely-generated upgrade code. The person types
# that code in the iOS debug area's "Upgrade to Admin" row to claim it.
# There is no shared upgrade code to configure here.

# --- Backups (restic) ---
#
# The dev backup container runs on demand:
#   docker compose --profile backup run --rm backup
# Or from the CLI: goldilocks --dev → Backups → Run backup now
#
# The dev restic passphrase lives at dev/restic-passphrase.dev
# (gitignored, created by setup). Dev-only — never reuse the prod
# passphrase here.
#
# Path to the iOS source repo, mounted read-only by the backup
# container so git bundle can run against it. Default assumes the
# goldilocks-ios checkout sits next to goldilocks-backend.
HOST_GOLDILOCKS_IOS_DIR=../goldilocks-ios

# --- Sealed secrets (SOPS + age) ---
#
# This .env.dev file is the runtime cache. The canonical encrypted form
# is at secrets/dev.env.enc, encrypted to the recipient in
# secrets/.age/dev.key.pub. The CLI keeps the two in sync:
#
#   - Settings → Run setup       generates the age key + initial seal
#   - Settings → Keys → Seal     re-encrypts after you edit this file
#   - Settings → Keys → Unseal   regenerates this file from the .enc
#   - (auto)                     CLI session start unseals if the
#                                .enc file is newer than this one
#
# Neither secrets/.age/dev.key (private) nor .env.dev (this file) is
# committed. secrets/dev.env.enc IS committable.
